generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  address      String?
  telephone    String      @unique
  taxId        String?     @unique
  role         Role
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  latitude     Float?
  longitude    Float?
  createdAt    DateTime    @default(now())
  driverOrders Order[]     @relation("DriverOrders")
  orders       Order[]
}

model Restaurant {
  id             String                    @id @default(uuid())
  name           String
  address        String
  taxId          String?
  telephone      String?
  email          String?
  orderEmail     String?
  website        String?
  logo           String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime                  @default(now())
  regimeIva      String?
  orderItems     OrderItem[]
  products       Product[]
  paymentMethods RestaurantPaymentMethod[]
  workingHours   RestaurantWorkingHour[]
  staff          User[]
}

model RestaurantPaymentMethod {
  id           String        @id @default(uuid())
  restaurantId String
  method       PaymentMethod
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
}

model RestaurantWorkingHour {
  id           String     @id @default(uuid())
  restaurantId String
  dayOfWeek    WeekDay    @default(MONDAY)
  startTime    String
  endTime      String
  isOpen       Boolean    @default(true)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Product {
  id            String        @id @default(uuid())
  name          String
  price         Float
  taxPercentage TaxPercentage @default(VAT_14)
  image1        String?
  image2        String?
  image3        String?
  image4        String?
  restaurantId  String
  orderItems    OrderItem[]
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
}

model Order {
  id                 String      @id @default(uuid())
  orderCounter       Int         @unique @default(autoincrement())
  total              Float
  totalIVA           Float       @default(0)
  platformTax        Float       @default(0)
  deliveryTax        Float       @default(0)
  deliveryFee        Float       @default(0)
  userId             String
  status             OrderStatus @default(PENDING)
  createdAt          DateTime    @default(now())
  driverId           String?
  driverLatitude     Float?
  driverLongitude    Float?
  lastLocationUpdate DateTime?
  driver             User?       @relation("DriverOrders", fields: [driverId], references: [id])
  user               User        @relation(fields: [userId], references: [id])
  items              OrderItem[]
}

model OrderItem {
  id            String        @id @default(uuid())
  quantity      Int           @default(1)
  price         Float
  taxPercentage TaxPercentage @default(VAT_14)
  orderId       String
  productId     String
  restaurantId  String
  order         Order         @relation(fields: [orderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
}

enum Role {
  CLIENT
  DRIVER
  RESTAURANT
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ACCEPTED_DRIVER
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD_ON_DELIVERY
  UNITEL_MONEY
  AFRICELL_CASH
  EMIS_REFERENCE
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TaxPercentage {
  VAT_14
  VAT_7
  VAT_5
}
